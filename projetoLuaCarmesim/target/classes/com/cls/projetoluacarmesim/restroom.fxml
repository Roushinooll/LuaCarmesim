<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Ellipse?>
<?import javafx.scene.shape.Rectangle?>

<Pane prefWidth="1280.0" prefHeight="720.0"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cls.projetoluacarmesim.RestroomController">

   <children>

      <!-- Fundo simples da restroom -->
      <Rectangle layoutX="0.0" layoutY="0.0" width="1280.0" height="720.0"
                 style="-fx-fill: #151018;" />
      <Rectangle layoutX="0.0" layoutY="430.0" width="1280.0" height="290.0"
                 style="-fx-fill: #221823;" />

      <!-- Mesa -->
      <Rectangle fx:id="mesa"
                 layoutX="220.0"
                 layoutY="260.0"
                 width="170.0"
                 height="100.0"
                 style="-fx-fill: #4a2b1a; -fx-stroke: #1c0f08; -fx-stroke-width: 3px;" />

      <!-- Caldeirão visual -->
      <Rectangle layoutX="557.0" layoutY="348.0" width="136.0" height="18.0" arcWidth="10.0" arcHeight="10.0"
                 style="-fx-fill: #080b09;" />
      <Ellipse layoutX="625.0" layoutY="322.0" radiusX="91.0" radiusY="50.0"
               style="-fx-fill: #101c16; -fx-stroke: #5fd182; -fx-stroke-width: 4px;" />
      <Rectangle layoutX="552.0" layoutY="282.0" width="146.0" height="54.0"
                 style="-fx-fill: #101c16;" />
      <Ellipse layoutX="625.0" layoutY="282.0" radiusX="96.0" radiusY="30.0"
               style="-fx-fill: #0a120f; -fx-stroke: #7cff9e; -fx-stroke-width: 4px;" />
      <Ellipse layoutX="625.0" layoutY="280.0" radiusX="75.0" radiusY="20.0"
               style="-fx-fill: #2b8a56;" />
      <Circle layoutX="590.0" layoutY="255.0" radius="8.0" style="-fx-fill: #89ffb0;" />
      <Circle layoutX="625.0" layoutY="242.0" radius="6.0" style="-fx-fill: #b8ffd0;" />
      <Circle layoutX="662.0" layoutY="259.0" radius="7.0" style="-fx-fill: #89ffb0;" />
      <Label layoutX="565.0"
             layoutY="382.0"
             text="CALDEIRÃO"
             style="-fx-text-fill: #b7f7c5; -fx-font-size: 18px; -fx-font-weight: bold;" />

      <!-- Hitbox maior e invisível do caldeirão. Evita interação falhando por causa do desenho arredondado. -->
      <Rectangle fx:id="caldeirao"
                 layoutX="500.0"
                 layoutY="230.0"
                 width="250.0"
                 height="185.0"
                 opacity="0.0"
                 style="-fx-fill: white;" />

      <!-- Porta -->
      <Rectangle fx:id="porta"
                 layoutX="1070.0"
                 layoutY="240.0"
                 width="90.0"
                 height="190.0"
                 style="-fx-fill: #2b1a10; -fx-stroke: #0f0804; -fx-stroke-width: 3px;" />

      <!-- Personagem -->
      <ImageView fx:id="personagemView"
                 layoutX="120.0"
                 layoutY="120.0" />

      <!-- Texto de interação -->
      <Label fx:id="textoInteracao"
             layoutX="310.0"
             layoutY="640.0"
             prefWidth="660.0"
             text=""
             wrapText="true"
             style="-fx-text-fill: white; -fx-font-size: 24px;" />

      <!-- Caixa de diálogo estilo jogo -->
      <Pane fx:id="caixaDialogo"
            layoutX="290.0"
            layoutY="470.0"
            prefWidth="700.0"
            prefHeight="180.0"
            visible="false"
            style="
                -fx-background-color: rgba(10, 5, 8, 0.92);
                -fx-border-color: #8b1e2d;
                -fx-border-width: 3px;
                -fx-border-radius: 8px;
                -fx-background-radius: 8px;
            ">

         <children>
            <Label fx:id="textoDialogo"
                   layoutX="35.0"
                   layoutY="25.0"
                   prefWidth="630.0"
                   prefHeight="90.0"
                   text="Tem certeza que não esqueceu nada?"
                   wrapText="true"
                   style="
                       -fx-text-fill: #f5e6d0;
                       -fx-font-size: 24px;
                       -fx-font-family: 'Georgia';
                   " />

            <Label fx:id="textoInstrucaoDialogo"
                   layoutX="35.0"
                   layoutY="125.0"
                   text="ENTER / ESPAÇO - Continuar"
                   style="
                       -fx-text-fill: #c96b6b;
                       -fx-font-size: 18px;
                       -fx-font-family: 'Georgia';
                   " />
         </children>
      </Pane>

      <!-- Painel interno do caldeirão, sem popup externo bugando foco -->
      <Pane fx:id="painelCaldeirao"
            layoutX="240.0"
            layoutY="105.0"
            prefWidth="800.0"
            prefHeight="510.0"
            visible="false"
            focusTraversable="true"
            style="
                -fx-background-color: rgba(8, 13, 10, 0.96);
                -fx-border-color: #68d391;
                -fx-border-width: 4px;
                -fx-border-radius: 10px;
                -fx-background-radius: 10px;
            ">

         <children>
            <Label layoutX="35.0"
                   layoutY="25.0"
                   text="Caldeirão de Poções"
                   style="-fx-text-fill: #b7f7c5; -fx-font-size: 30px; -fx-font-weight: bold;" />

            <Label layoutX="35.0"
                   layoutY="67.0"
                   text="Escolha uma receita aprendida. ENTER crafta, ESC fecha."
                   style="-fx-text-fill: #d8ffe0; -fx-font-size: 16px;" />

            <ListView fx:id="listaReceitasCaldeirao"
                      layoutX="35.0"
                      layoutY="105.0"
                      prefWidth="730.0"
                      prefHeight="185.0" />

            <Label fx:id="textoCaldeirao"
                   layoutX="35.0"
                   layoutY="310.0"
                   prefWidth="730.0"
                   prefHeight="105.0"
                   wrapText="true"
                   text="Escolha uma receita."
                   style="-fx-text-fill: #f5e6d0; -fx-font-size: 17px;" />

            <Button fx:id="botaoCraftar"
                    layoutX="510.0"
                    layoutY="438.0"
                    prefWidth="120.0"
                    prefHeight="38.0"
                    text="Craftar"
                    onAction="#craftarReceitaSelecionada" />

            <Button layoutX="645.0"
                    layoutY="438.0"
                    prefWidth="120.0"
                    prefHeight="38.0"
                    text="Fechar"
                    onAction="#fecharCaldeirao" />
         </children>
      </Pane>

   </children>
</Pane>
