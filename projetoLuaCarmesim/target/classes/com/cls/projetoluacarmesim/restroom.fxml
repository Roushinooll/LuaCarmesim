<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Rectangle?>

<Pane prefWidth="1280.0" prefHeight="720.0"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cls.projetoluacarmesim.RestroomController">

   <children>

      <!-- Background artístico do quarto. O controller alterna entre restroom_gun e restroom_without. -->
      <ImageView fx:id="fundoRestroom"
                 layoutX="0.0"
                 layoutY="0.0"
                 fitWidth="1280.0"
                 fitHeight="720.0"
                 preserveRatio="false"
                 smooth="false"
                 mouseTransparent="true" />

      <!-- Hitboxes invisíveis dos objetos interativos do cenário novo. -->
      <Rectangle fx:id="mesa"
                 layoutX="605.0"
                 layoutY="448.0"
                 width="360.0"
                 height="150.0"
                 opacity="0.0"
                 style="-fx-fill: white;" />

      <Rectangle fx:id="caldeirao"
                 layoutX="790.0"
                 layoutY="95.0"
                 width="390.0"
                 height="210.0"
                 opacity="0.0"
                 style="-fx-fill: white;" />

      <Rectangle fx:id="porta"
                 layoutX="35.0"
                 layoutY="160.0"
                 width="130.0"
                 height="290.0"
                 opacity="0.0"
                 style="-fx-fill: white;" />

      <!-- Personagem -->
      <ImageView fx:id="personagemView"
                 layoutX="235.0"
                 layoutY="405.0" />

      <!-- Texto de interação -->
      <Label fx:id="textoInteracao"
             layoutX="310.0"
             layoutY="640.0"
             prefWidth="660.0"
             text=""
             wrapText="true"
             style="-fx-text-fill: white; -fx-font-size: 24px;" />

      <!-- Caixa de diálogo estilo jogo -->
      <Pane fx:id="caixaDialogo"
            layoutX="290.0"
            layoutY="470.0"
            prefWidth="700.0"
            prefHeight="180.0"
            visible="false"
            style="
                -fx-background-color: rgba(10, 5, 8, 0.92);
                -fx-border-color: #8b1e2d;
                -fx-border-width: 3px;
                -fx-border-radius: 8px;
                -fx-background-radius: 8px;
            ">

         <children>
            <Label fx:id="textoDialogo"
                   layoutX="35.0"
                   layoutY="25.0"
                   prefWidth="630.0"
                   prefHeight="90.0"
                   text="Tem certeza que não esqueceu nada?"
                   wrapText="true"
                   style="
                       -fx-text-fill: #f5e6d0;
                       -fx-font-size: 24px;
                       -fx-font-family: 'Georgia';
                   " />

            <Label fx:id="textoInstrucaoDialogo"
                   layoutX="35.0"
                   layoutY="125.0"
                   text="ENTER / ESPAÇO - Continuar"
                   style="
                       -fx-text-fill: #c96b6b;
                       -fx-font-size: 18px;
                       -fx-font-family: 'Georgia';
                   " />
         </children>
      </Pane>

      <!-- Painel interno do caldeirão, sem popup externo bugando foco -->
      <Pane fx:id="painelCaldeirao"
            layoutX="240.0"
            layoutY="105.0"
            prefWidth="800.0"
            prefHeight="510.0"
            visible="false"
            focusTraversable="true"
            style="
                -fx-background-color: rgba(8, 13, 10, 0.96);
                -fx-border-color: #68d391;
                -fx-border-width: 4px;
                -fx-border-radius: 10px;
                -fx-background-radius: 10px;
            ">

         <children>
            <Label layoutX="35.0"
                   layoutY="25.0"
                   text="Caldeirão de Poções"
                   style="-fx-text-fill: #b7f7c5; -fx-font-size: 30px; -fx-font-weight: bold;" />

            <Label layoutX="35.0"
                   layoutY="67.0"
                   text="Escolha uma receita aprendida. ENTER crafta, ESC fecha."
                   style="-fx-text-fill: #d8ffe0; -fx-font-size: 16px;" />

            <ListView fx:id="listaReceitasCaldeirao"
                      layoutX="35.0"
                      layoutY="105.0"
                      prefWidth="730.0"
                      prefHeight="185.0" />

            <Label fx:id="textoCaldeirao"
                   layoutX="35.0"
                   layoutY="310.0"
                   prefWidth="730.0"
                   prefHeight="105.0"
                   wrapText="true"
                   text="Escolha uma receita."
                   style="-fx-text-fill: #f5e6d0; -fx-font-size: 17px;" />

            <Button fx:id="botaoCraftar"
                    layoutX="510.0"
                    layoutY="438.0"
                    prefWidth="120.0"
                    prefHeight="38.0"
                    text="Craftar"
                    onAction="#craftarReceitaSelecionada" />

            <Button layoutX="645.0"
                    layoutY="438.0"
                    prefWidth="120.0"
                    prefHeight="38.0"
                    text="Fechar"
                    onAction="#fecharCaldeirao" />
         </children>
      </Pane>

   </children>
</Pane>
