<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootInventario"
      prefWidth="1280.0"
      prefHeight="720.0"
      spacing="18.0"
      style="-fx-background-color: #0b0508; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cls.projetoluacarmesim.InventarioController">

    <children>

        <HBox spacing="30.0" style="-fx-alignment: center-left;">
            <children>
                <Label text="Inventário"
                       style="-fx-text-fill: #f5e6d0; -fx-font-size: 34px; -fx-font-weight: bold;" />

                <Label fx:id="labelMoedas"
                       text="Moedas de Ouro: 0"
                       style="-fx-text-fill: #d4af37; -fx-font-size: 22px; -fx-font-weight: bold;" />
            </children>
        </HBox>

        <HBox spacing="12.0">
            <children>
                <Button fx:id="btnTudo"
                        text="1 - Tudo"
                        onAction="#mostrarTudo"
                        focusTraversable="false"
                        prefWidth="170.0" />

                <Button fx:id="btnIngredientes"
                        text="2 - Ingredientes"
                        onAction="#mostrarIngredientes"
                        focusTraversable="false"
                        prefWidth="210.0" />

                <Button fx:id="btnPocoes"
                        text="3 - Poções feitas"
                        onAction="#mostrarPocoes"
                        focusTraversable="false"
                        prefWidth="210.0" />

                <Button fx:id="btnReceitas"
                        text="4 - Receitas"
                        onAction="#mostrarReceitas"
                        focusTraversable="false"
                        prefWidth="190.0" />
            </children>
        </HBox>

        <VBox spacing="10.0">
            <children>
                <Label fx:id="labelTituloAba"
                       text="Tudo"
                       style="-fx-text-fill: #c96b6b; -fx-font-size: 26px; -fx-font-weight: bold;" />

                <ListView fx:id="listaItens"
                          prefWidth="1160.0"
                          prefHeight="475.0"
                          focusTraversable="true"
                          style="-fx-control-inner-background: #150b10; -fx-background-color: rgba(245,230,208,0.08); -fx-text-fill: #f5e6d0;" />
            </children>
        </VBox>

        <VBox spacing="4.0">
            <children>
                <Label text="I - Voltar     ENTER - Usar item selecionado     1/2/3/4 - Trocar aba"
                       style="-fx-text-fill: #f5e6d0; -fx-font-size: 18px;" />

                <Label fx:id="labelInstrucaoUso"
                       text="ENTER - Usar item selecionado quando ele possuir interação."
                       style="-fx-text-fill: rgba(245,230,208,0.72); -fx-font-size: 15px;" />
            </children>
        </VBox>

    </children>
</VBox>
