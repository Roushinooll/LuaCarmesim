<VBox alignment="CENTER" prefHeight="696.0" prefWidth="1159.0" spacing="20.0" stylesheets="@../../../Styles/MenuStyle.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cls.projetoluacarmesim.MenuController">
   <children>
      <ImageView fitHeight="193.0" fitWidth="574.0" pickOnBounds="true" preserveRatio="true">
