            <Image url="@../../../image/logo.png" />
         </image>
      </ImageView>
      <Button fx:id="jogador" onAction="#jogar" prefHeight="43.0" prefWidth="127.0" stylesheets="@../../../Styles/MenuStyle.css" text="Jogar" />
      <Button fx:id="opcoes" onAction="#opcoes" prefHeight="43.0" prefWidth="128.0" stylesheets="@../../../Styles/MenuStyle.css" text="Opções" />
      <Button fx:id="ranking" onAction="#ranking" stylesheets="@../../../Styles/MenuStyle.css" text="Ranking" />
      <Button fx:id="creditos" onAction="#creditos" stylesheets="@../../../Styles/MenuStyle.css" text="Creditos" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
