<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootInventario"
      prefWidth="1280.0"
      prefHeight="720.0"
      spacing="20.0"
      style="-fx-background-color: #0b0508; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cls.projetoluacarmesim.InventarioController">

    <children>

        <Label text="Inventário"
               style="-fx-text-fill: #f5e6d0; -fx-font-size: 34px;" />

        <HBox spacing="40.0">
            <children>

                <VBox spacing="10.0">
                    <children>
                        <Label text="Itens"
                               style="-fx-text-fill: #c96b6b; -fx-font-size: 24px;" />

                        <ListView fx:id="listaItens"
                                  prefWidth="550.0"
                                  prefHeight="520.0"
                                  focusTraversable="true" />
                    </children>
                </VBox>

                <VBox spacing="10.0">
                    <children>
                        <Label text="Receitas Obtidas"
                               style="-fx-text-fill: #c96b6b; -fx-font-size: 24px;" />

                        <ListView fx:id="listaReceitas"
                                  prefWidth="550.0"
                                  prefHeight="520.0"
                                  focusTraversable="false" />
                    </children>
                </VBox>

            </children>
        </HBox>

        <Label text="I - Voltar     ENTER - Tomar poção selecionada"
               style="-fx-text-fill: #f5e6d0; -fx-font-size: 18px;" />

    </children>
</VBox>