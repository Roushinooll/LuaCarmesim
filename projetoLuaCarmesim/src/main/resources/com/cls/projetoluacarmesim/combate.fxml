<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<StackPane prefWidth="1280.0"
           prefHeight="720.0"
           style="-fx-background-color: #050308;"
           xmlns="http://javafx.com/javafx/13"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.cls.projetoluacarmesim.CombateController">
    <children>
        <ImageView fx:id="imagemFundoBatalha"
                   fitWidth="1280.0"
                   fitHeight="720.0"
                   preserveRatio="false"
                   smooth="true" />

        <Rectangle width="1280.0"
                   height="720.0"
                   fill="#000000" opacity="0.20" />

        <VBox prefWidth="1280.0" prefHeight="720.0" spacing="0.0">
            <children>
                <VBox prefHeight="92.0"
                      spacing="6.0"
                      style="-fx-background-color: rgba(0,0,0,0.42); -fx-border-color: rgba(132, 31, 52, 0.78); -fx-border-width: 0 0 2 0;">
                    <padding>
                        <Insets top="14.0" right="24.0" bottom="10.0" left="24.0" />
                    </padding>
                    <children>
                        <Label fx:id="labelTitulo"
                               text="Combate"
                               style="-fx-text-fill: #f5e6d0; -fx-font-size: 30px; -fx-font-family: Georgia; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, black, 4, 0.8, 2, 2);" />

                        <HBox spacing="30.0">
                            <children>
                                <Label fx:id="labelTurno"
                                       text="Turno 1"
                                       style="-fx-text-fill: #e4d2bd; -fx-font-size: 16px; -fx-font-family: Georgia; -fx-effect: dropshadow(gaussian, black, 2, 0.8, 1, 1);" />

                                <Label fx:id="labelAcoes"
                                       text="Ação disponível"
                                       style="-fx-text-fill: #ffd27a; -fx-font-size: 16px; -fx-font-family: Georgia; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, black, 2, 0.8, 1, 1);" />

                                <Label fx:id="labelMunicao"
                                       text="Revólver: 6/6 balas"
                                       style="-fx-text-fill: #f0d08b; -fx-font-size: 16px; -fx-font-family: Georgia; -fx-effect: dropshadow(gaussian, black, 2, 0.8, 1, 1);" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Pane prefWidth="1280.0" prefHeight="388.0">
                    <children>
                        <VBox layoutX="86.0"
                              layoutY="28.0"
                              prefWidth="355.0"
                              prefHeight="92.0"
                              spacing="6.0"
                              style="-fx-background-color: rgba(18, 8, 12, 0.76); -fx-border-color: rgba(210, 75, 94, 0.88); -fx-border-width: 2px; -fx-border-radius: 12px; -fx-background-radius: 12px;">
                            <padding>
                                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
                            </padding>
                            <children>
                                <Label fx:id="labelInimigo"
                                       text="Inimigo | Vida: 100/100"
                                       wrapText="true"
                                       style="-fx-text-fill: #fff2f4; -fx-font-size: 14px; -fx-font-family: Georgia; -fx-font-weight: bold;" />
                                <ProgressBar fx:id="barraVidaInimigo"
                                             progress="1.0"
                                             prefWidth="325.0"
                                             prefHeight="12.0"
                                             style="-fx-accent: #b93144;" />
                                <ProgressBar fx:id="barraSanidadeInimigo"
                                             progress="1.0"
                                             prefWidth="325.0"
                                             prefHeight="8.0"
                                             style="-fx-accent: #6b62d8;" />
                            </children>
                        </VBox>

                        <ImageView fx:id="spriteInimigoBatalha"
                                   layoutX="962.0"
                                   layoutY="126.0"
                                   fitWidth="176.0"
                                   fitHeight="176.0"
                                   preserveRatio="true"
                                   smooth="false" />

                        <VBox layoutX="760.0"
                              layoutY="254.0"
                              prefWidth="365.0"
                              prefHeight="100.0"
                              spacing="6.0"
                              style="-fx-background-color: rgba(9, 14, 23, 0.78); -fx-border-color: rgba(84, 130, 170, 0.88); -fx-border-width: 2px; -fx-border-radius: 12px; -fx-background-radius: 12px;">
                            <padding>
                                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
                            </padding>
                            <children>
                                <Label fx:id="labelJogador"
                                       text="Jogador | Vida: 100/100"
                                       wrapText="true"
                                       style="-fx-text-fill: #edf7ff; -fx-font-size: 14px; -fx-font-family: Georgia; -fx-font-weight: bold;" />
                                <ProgressBar fx:id="barraVidaJogador"
                                             progress="1.0"
                                             prefWidth="335.0"
                                             prefHeight="12.0"
                                             style="-fx-accent: #4d9f74;" />
                                <ProgressBar fx:id="barraSanidadeJogador"
                                             progress="1.0"
                                             prefWidth="335.0"
                                             prefHeight="8.0"
                                             style="-fx-accent: #6b62d8;" />
                            </children>
                        </VBox>

                        <ImageView fx:id="spriteJogadorBatalha"
                                   layoutX="230.0"
                                   layoutY="202.0"
                                   fitWidth="190.0"
                                   fitHeight="190.0"
                                   preserveRatio="true"
                                   smooth="false" />
                    </children>
                </Pane>

                <HBox prefHeight="240.0"
                      spacing="18.0"
                      style="-fx-background-color: rgba(5, 3, 8, 0.64); -fx-border-color: rgba(111, 29, 45, 0.92); -fx-border-width: 2 0 0 0;">
                    <padding>
                        <Insets top="18.0" right="24.0" bottom="18.0" left="24.0" />
                    </padding>
                    <children>
                        <VBox prefWidth="350.0"
                              prefHeight="204.0"
                              style="-fx-background-color: rgba(18, 11, 18, 0.72); -fx-border-color: rgba(245, 230, 208, 0.25); -fx-border-width: 1.5px; -fx-border-radius: 14px; -fx-background-radius: 14px;">
                            <padding>
                                <Insets top="12.0" right="14.0" bottom="12.0" left="14.0" />
                            </padding>
                            <children>
                                <VBox fx:id="menuAcoesPrincipais" spacing="8.0" prefWidth="322.0">
                                    <children>
                                        <Label text="O que você vai fazer?"
                                               style="-fx-text-fill: #f5e6d0; -fx-font-size: 16px; -fx-font-family: Georgia; -fx-font-weight: bold;" />

                                        <Button fx:id="botaoAtacar"
                                                text="Ataque físico"
                                                onAction="#atacarFisico"
                                                prefWidth="310.0"
                                                prefHeight="34.0"
                                                style="-fx-font-size: 14px; -fx-font-family: Georgia; -fx-background-radius: 8px;" />

                                        <Button fx:id="botaoAtirar"
                                                text="Atirar com Revólver"
                                                onAction="#atirarRevolver"
                                                prefWidth="310.0"
                                                prefHeight="34.0"
                                                style="-fx-font-size: 14px; -fx-font-family: Georgia; -fx-background-radius: 8px;" />

                                        <Button fx:id="botaoDefender"
                                                text="Defender"
                                                onAction="#defender"
                                                prefWidth="310.0"
                                                prefHeight="34.0"
                                                style="-fx-font-size: 14px; -fx-font-family: Georgia; -fx-background-radius: 8px;" />

                                        <Button fx:id="botaoConversar"
                                                text="Arte da Conversa"
                                                onAction="#conversar"
                                                prefWidth="310.0"
                                                prefHeight="34.0"
                                                style="-fx-font-size: 14px; -fx-font-family: Georgia; -fx-background-radius: 8px;" />

                                        <Button fx:id="botaoAbrirHabilidades"
                                                text="Habilidades"
                                                onAction="#abrirMenuHabilidades"
                                                prefWidth="310.0"
                                                prefHeight="34.0"
                                                style="-fx-font-size: 14px; -fx-font-family: Georgia; -fx-background-radius: 8px;" />
                                    </children>
                                </VBox>

                                <VBox fx:id="menuHabilidadesCombate"
                                      spacing="8.0"
                                      prefWidth="322.0"
                                      visible="false"
                                      managed="false">
                                    <children>
                                        <Label text="Habilidades de Caminho"
                                               wrapText="true"
                                               prefWidth="310.0"
                                               style="-fx-text-fill: #f5e6d0; -fx-font-size: 16px; -fx-font-family: Georgia; -fx-font-weight: bold;" />

                                        <Label text="Clique em uma habilidade para usar. Isso encerra sua ação."
                                               wrapText="true"
                                               prefWidth="310.0"
                                               style="-fx-text-fill: #d0a4aa; -fx-font-size: 12px; -fx-font-family: Georgia;" />

                                        <ScrollPane fitToWidth="true"
                                                    hbarPolicy="NEVER"
                                                    vbarPolicy="AS_NEEDED"
                                                    prefWidth="315.0"
                                                    prefHeight="112.0"
                                                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 0;">
                                            <content>
                                                <VBox fx:id="boxBotoesHabilidades"
                                                      spacing="6.0"
                                                      prefWidth="310.0" />
                                            </content>
                                        </ScrollPane>

                                        <Button fx:id="botaoVoltarAcoes"
                                                text="Voltar"
                                                onAction="#voltarMenuAcoes"
                                                prefWidth="310.0"
                                                prefHeight="34.0"
                                                style="-fx-font-size: 14px; -fx-font-family: Georgia; -fx-background-radius: 8px;" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox prefWidth="610.0"
                              prefHeight="204.0"
                              spacing="8.0"
                              style="-fx-background-color: rgba(12, 7, 12, 0.70); -fx-border-color: rgba(245, 230, 208, 0.25); -fx-border-width: 1.5px; -fx-border-radius: 14px; -fx-background-radius: 14px;">
                            <padding>
                                <Insets top="12.0" right="14.0" bottom="12.0" left="14.0" />
                            </padding>
                            <children>
                                <Label text="Registro do Combate"
                                       style="-fx-text-fill: #f5e6d0; -fx-font-size: 16px; -fx-font-family: Georgia; -fx-font-weight: bold;" />
                                <TextArea fx:id="logCombate"
                                          editable="false"
                                          wrapText="true"
                                          prefWidth="582.0"
                                          prefHeight="156.0"
                                          style="-fx-control-inner-background: rgba(0,0,0,0.35); -fx-text-fill: #f5e6d0; -fx-font-size: 14px; -fx-font-family: Georgia; -fx-background-color: transparent;" />
                            </children>
                        </VBox>

                        <VBox spacing="14.0"
                              prefWidth="210.0"
                              prefHeight="204.0"
                              style="-fx-background-color: rgba(18, 11, 18, 0.72); -fx-border-color: rgba(245, 230, 208, 0.25); -fx-border-width: 1.5px; -fx-border-radius: 14px; -fx-background-radius: 14px;">
                            <padding>
                                <Insets top="14.0" right="10.0" bottom="14.0" left="10.0" />
                            </padding>
                            <children>
                                <Button fx:id="botaoFugir"
                                        text="Fugir"
                                        onAction="#fugir"
                                        prefWidth="190.0"
                                        prefHeight="46.0"
                                        style="-fx-font-size: 14px; -fx-font-family: Georgia; -fx-background-radius: 8px;" />

                                <Label text="Cada turno permite só uma ação. Habilidades, conversa, defesa, ataque físico e tiro encerram sua ação."
                                       wrapText="true"
                                       prefWidth="190.0"
                                       style="-fx-text-fill: #d0a4aa; -fx-font-size: 12px; -fx-font-family: Georgia;" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
