<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>

<Pane fx:id="rootRua"
      prefWidth="1280.0"
      prefHeight="720.0"
      style="-fx-background-color: #0c0a0e;"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cls.projetoluacarmesim.StreetsController">

    <children>

        <Pane fx:id="camadaCenario"
              prefWidth="1280.0"
              prefHeight="720.0" />

        <Pane fx:id="camadaObjetos"
              prefWidth="1280.0"
              prefHeight="720.0" />

        <ImageView fx:id="personagemView"
                   fitWidth="48.0"
                   fitHeight="64.0"
                   layoutX="70.0"
                   layoutY="300.0" />

        <Label fx:id="textoInfo"
               layoutX="30.0"
               layoutY="25.0"
               text=""
               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-family: Georgia;" />

        <Label fx:id="textoInteracao"
               layoutX="350.0"
               layoutY="640.0"
               text=""
               style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-family: Georgia;" />

    </children>
</Pane>