<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>

<Pane fx:id="rootRua"
      prefWidth="1280.0"
      prefHeight="720.0"
      style="-fx-background-color: #0c0a0e;"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cls.projetoluacarmesim.StreetsController">

    <children>

        <Pane fx:id="camadaCenario"
              prefWidth="1280.0"
              prefHeight="720.0" />

        <Pane fx:id="camadaObjetos"
              prefWidth="1280.0"
              prefHeight="720.0" />

        <ImageView fx:id="personagemView"
                   fitWidth="48.0"
                   fitHeight="64.0"
                   layoutX="70.0"
                   layoutY="300.0" />

        <Label fx:id="textoInfo"
               layoutX="30.0"
               layoutY="25.0"
               text=""
               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-family: Georgia;" />

        <Label fx:id="textoInteracao"
               layoutX="350.0"
               layoutY="640.0"
               text=""
               style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-family: Georgia;" />

        
        <Pane fx:id="menuRua"
              layoutX="390.0"
              layoutY="115.0"
              prefWidth="500.0"
              prefHeight="500.0"
              visible="false"
              focusTraversable="true"
              style="
                  -fx-background-color: rgba(8, 5, 10, 0.96);
                  -fx-border-color: #8b1e2d;
                  -fx-border-width: 4px;
                  -fx-border-radius: 10px;
                  -fx-background-radius: 10px;
              ">
            <children>
                <Label layoutX="0.0"
                       layoutY="30.0"
                       prefWidth="500.0"
                       alignment="CENTER"
                       text="Menu"
                       style="-fx-text-fill: #f5e6d0; -fx-font-size: 34px; -fx-font-family: Georgia; -fx-font-weight: bold;" />

                <Label layoutX="45.0"
                       layoutY="83.0"
                       prefWidth="410.0"
                       text="TAB abre e fecha este menu. Escolha uma opção para pausar a exploração."
                       wrapText="true"
                       style="-fx-text-fill: #c9b7a0; -fx-font-size: 17px; -fx-font-family: Georgia;" />

                <Button fx:id="botaoInventarioMenu"
                        layoutX="120.0"
                        layoutY="142.0"
                        prefWidth="260.0"
                        prefHeight="43.0"
                        text="Inventário"
                        onAction="#abrirInventario"
                        style="-fx-font-size: 17px; -fx-font-family: Georgia;" />

                <Button layoutX="120.0"
                        layoutY="197.0"
                        prefWidth="260.0"
                        prefHeight="43.0"
                        text="Habilidades"
                        onAction="#abrirHabilidadesPeloMenu"
                        style="-fx-font-size: 17px; -fx-font-family: Georgia;" />

                <Button fx:id="botaoVoltarRestroom"
                        layoutX="120.0"
                        layoutY="252.0"
                        prefWidth="260.0"
                        prefHeight="43.0"
                        text="Voltar Para o quarto"
                        onAction="#voltarParaRestroomPeloMenu"
                        style="-fx-font-size: 17px; -fx-font-family: Georgia;" />

                <Button layoutX="120.0"
                        layoutY="307.0"
                        prefWidth="260.0"
                        prefHeight="43.0"
                        text="Opções"
                        onAction="#abrirOpcoesPeloMenu"
                        style="-fx-font-size: 17px; -fx-font-family: Georgia;" />

                <Button layoutX="120.0"
                        layoutY="362.0"
                        prefWidth="260.0"
                        prefHeight="43.0"
                        text="Sair"
                        onAction="#sairDoJogoPeloMenu"
                        style="-fx-font-size: 17px; -fx-font-family: Georgia;" />

                <Button layoutX="165.0"
                        layoutY="424.0"
                        prefWidth="170.0"
                        prefHeight="34.0"
                        text="Fechar"
                        onAction="#fecharMenuRua"
                        style="-fx-font-size: 15px; -fx-font-family: Georgia;" />

                <Label layoutX="0.0"
                       layoutY="468.0"
                       prefWidth="500.0"
                       alignment="CENTER"
                       text="TAB ou ESC fecha"
                       style="-fx-text-fill: #a5535d; -fx-font-size: 14px; -fx-font-family: Georgia;" />
            </children>
        </Pane>

    </children>
</Pane>